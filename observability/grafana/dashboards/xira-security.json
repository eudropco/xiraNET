            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["sum"]},
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "sum by (category) (increase(xiranet_ssrf_rejects_total[1h]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
