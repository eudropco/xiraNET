  "panels": [
    {
      "title": "Auth Rejects (5m rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (category) (rate(xiranet_auth_rejects_total[5m]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "WAF Blocks (5m rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (rule) (rate(xiranet_waf_blocks_total[5m]))",
